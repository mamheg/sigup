# ─── SiGup deploy config (скопируй в deploy/.env и заполни) ───

# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# Админ платформы (создаётся сидом при первом старте)
ADMIN_EMAIL=admin@sigup.ru
ADMIN_PASSWORD=change-me-strong-password

# SMTP — коды подтверждения email и восстановления пароля
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=SiGup <noreply@example.com>

# Домены фронтенда, которым разрешён CORS (через запятую)
CORS_ORIGINS=http://localhost,https://sigup.example.com

# Внешний HTTP-порт сайта
WEB_PORT=80

# ─── Локальная разработка фронтенда (не для прода) ───
# VITE_API_URL=http://localhost:8000/api

# Публичный адрес сайта (для sitemap.xml)
SITE_URL=https://sigup.example.com
