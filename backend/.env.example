# Database. Leave commented out (or unreachable) to fall back to local SQLite dev.db.
# DATABASE_URL=postgresql://sigup:sigup@localhost:5432/sigup

# SMTP for verification / password-reset codes
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=SiGup <your-email@example.com>

# Admin account created by seed.py
ADMIN_EMAIL=admin@sigup.ru
ADMIN_PASSWORD=change-me-to-a-strong-password

# Uploads directory (relative to backend/)
UPLOAD_DIR=static/uploads

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth session lifetime in days
SESSION_TTL_DAYS=30

# In DEBUG mode failed SMTP sends return the code in the response message
DEBUG=false
